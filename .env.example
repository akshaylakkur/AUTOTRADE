# =============================================================================
# Project ÆON — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit the real .env file — it is listed in .gitignore.
# =============================================================================


# ---------------------------------------------------------------------------
# Core / Operational Mode
# ---------------------------------------------------------------------------

# When enabled, ALL financial and deployment actions require human approval
# via email before execution.  Recommended during initial deployment and
# testing.  Set to "true" to activate restricted mode.
AEON_RESTRICTED_MODE=false


# ---------------------------------------------------------------------------
# LLM Provider
# ---------------------------------------------------------------------------
# Which LLM backend ÆON uses for decision-making, code generation, and
# self-analysis.  Supported values: "ollama", "anthropic", "openai".
# "ollama" is fully implemented; "anthropic" and "openai" are stored for
# future use (the system will fall back to ollama).
AEON_LLM_PROVIDER=ollama

# --- Ollama (local, free) ---
# Install:  https://ollama.com
# Pull a model:  ollama pull llama3.2

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Anthropic (Claude) — cloud API ---
# https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# --- Amazon Bedrock — cloud API ---
# Uses your AWS credentials to call models hosted on Bedrock
# (Claude, Llama, Titan, Mistral, etc.)
# https://console.aws.amazon.com/bedrock
# BEDROCK_AWS_ACCESS_KEY_ID=
# BEDROCK_AWS_SECRET_ACCESS_KEY=
# BEDROCK_AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# --- OpenAI (GPT) — cloud API ---
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=


# ---------------------------------------------------------------------------
# Approval Email (Human-in-the-Loop)
# ---------------------------------------------------------------------------
# SMTP settings used to send approval-request emails to a human operator.
# REQUIRED when AEON_RESTRICTED_MODE=true.

# SMTP server hostname (e.g. smtp.gmail.com, smtp.sendgrid.net)
AEON_APPROVAL_EMAIL_SMTP_HOST=

# SMTP port (default: 587 for TLS, 465 for SSL)
AEON_APPROVAL_EMAIL_SMTP_PORT=587

# Email address ÆON sends FROM
AEON_APPROVAL_EMAIL_SENDER=

# SMTP password or app-specific password
AEON_APPROVAL_EMAIL_PASSWORD=

# Email address of the human who approves/rejects actions
AEON_APPROVAL_EMAIL_RECIPIENT=

# Use STARTTLS (default: true).  Set to "false" for plain SMTP.
AEON_APPROVAL_EMAIL_USE_TLS=true


# ---------------------------------------------------------------------------
# Inbound Email (IMAP — Optional)
# ---------------------------------------------------------------------------
# Used by the email client (senses/communications/email_client.py) to read
# incoming approval responses and other communications.

AEON_EMAIL_IMAP_HOST=imap.gmail.com
AEON_EMAIL_IMAP_PORT=993
AEON_EMAIL_USER=
AEON_EMAIL_PASSWORD=


# ---------------------------------------------------------------------------
# Vault Encryption
# ---------------------------------------------------------------------------
# Master passphrase used to derive the PBKDF2 encryption key for the
# secret vault (auton/security/vault.py).  REQUIRED for production use.
# Generate with:  openssl rand -base64 32
AEON_VAULT_KEY=


# ---------------------------------------------------------------------------
# Outbound Notifications (auton/limbs/communications/notifications.py)
# ---------------------------------------------------------------------------

# Default recipient for system-generated notification emails
AEON_DEFAULT_EMAIL_RECIPIENT=

# Generic SMTP settings for outbound notifications (separate from approval
# emails; may point to the same server)
AEON_SMTP_HOST=smtp.gmail.com
AEON_SMTP_PORT=587
AEON_SMTP_USER=
AEON_SMTP_PASSWORD=

# SendGrid API key (alternative to direct SMTP)
AEON_SENDGRID_API_KEY=

# Amazon SES (alternative)
AEON_SES_ACCESS_KEY=
AEON_SES_SECRET_KEY=
AEON_SES_REGION=us-east-1

# Twilio SMS/Voice
AEON_TWILIO_ACCOUNT_SID=
AEON_TWILIO_AUTH_TOKEN=
AEON_TWILIO_PHONE_NUMBER=

# Default SMS recipient
AEON_DEFAULT_SMS_RECIPIENT=


# ---------------------------------------------------------------------------
# Exchange API Keys — Market Data & Trading
# ---------------------------------------------------------------------------

# Binance
# Create keys at: https://www.binance.com/en/support/faq/how-to-create-api-keys
# For testnet: use https://testnet.binance.vision
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Coinbase (Advanced Trade / Pro)
# Create keys at: https://www.coinbase.com/settings/api
COINBASE_API_KEY=
COINBASE_SECRET_KEY=


# ---------------------------------------------------------------------------
# Payments & Commerce
# ---------------------------------------------------------------------------

# Stripe — payment processing
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Stripe Crypto on-ramp key (auton/limbs/payments/crypto_onramp.py)
STRIPE_CRYPTO_SECRET_KEY=


# ---------------------------------------------------------------------------
# Banking (Plaid)
# ---------------------------------------------------------------------------
# Dashboard: https://dashboard.plaid.com/keys

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Access token obtained after Link flow (optional; skeleton mode if absent)
PLAID_ACCESS_TOKEN=


# ---------------------------------------------------------------------------
# Intelligence & Data Feeds
# ---------------------------------------------------------------------------

# SerpAPI — web search via Google
# https://serpapi.com/manage-api-key
SERPAPI_KEY=

# Brave Search API
# https://brave.com/search/api/
BRAVE_API_KEY=

# Twitter/X API (sentiment & social signals)
# https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=


# ---------------------------------------------------------------------------
# LLM / AI Providers
# ---------------------------------------------------------------------------
# Used by the cortex model router and metamind subsystems for reasoning,
# code generation, and strategic planning.

# Anthropic (Claude)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (GPT)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ---------------------------------------------------------------------------
# Deployment & Marketplace
# ---------------------------------------------------------------------------

# Render — cloud hosting for generated services
# https://dashboard.render.com/u/settings/api-keys
RENDER_API_KEY=

# Gumroad — digital product marketplace
# https://app.gumroad.com/settings/advanced
GUMROAD_API_KEY=
